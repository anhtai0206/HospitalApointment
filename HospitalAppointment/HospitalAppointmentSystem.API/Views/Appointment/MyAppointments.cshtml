@model List<AppointmentDetailDTO>
@{
    ViewData["Title"] = "Lịch khám của tôi";
    string StatusLabel(string status) => status switch
    {
        "Pending" => "Chờ xác nhận",
        "Confirmed" => "Đã xác nhận",
        "Completed" => "Đã khám",
        "Cancelled" => "Đã hủy",
        _ => status
    };
}

<section class="schedule-list full">
    <h3>Lịch khám của tôi</h3>
    <table>
        <thead>
            <tr>
                <th>Mã lịch hẹn</th>
                <th>Bác sĩ</th>
                <th>Chuyên khoa</th>
                <th>Dịch vụ</th>
                <th>Phòng khám</th>
                <th>Ngày khám</th>
                <th>Giờ khám</th>
                <th>Lý do</th>
                <th>Trạng thái</th>
                <th>Thao tác / Lý do hủy</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Any())
            {
                foreach (var a in Model)
                {
                    <tr>
                        <td>@a.AppointmentId</td>
                        <td>@a.DoctorName</td>
                        <td>@a.SpecialtyName</td>
                        <td>@a.MedicalServiceName</td>
                        <td>@a.ClinicRoomName</td>
                        <td>@a.WorkDate.ToString("dd/MM/yyyy")</td>
                        <td>@a.StartTime.ToString(@"hh\:mm") - @a.EndTime.ToString(@"hh\:mm")</td>
                        <td>@(string.IsNullOrWhiteSpace(a.Reason) ? "Không ghi" : a.Reason)</td>
                        <td><span class="status-pill @a.Status.ToLower()">@StatusLabel(a.Status)</span></td>
                        <td class="actions">
                            @if (a.Status == "Pending")
                            {
                                <form asp-action="CancelMine" method="post" onsubmit="return askCancelReason(this)">
                                    <input type="hidden" name="id" value="@a.AppointmentId" />
                                    <input type="hidden" name="cancelReason" />
                                    <button class="danger-button">Hủy lịch</button>
                                </form>
                            }
                            else if (a.Status == "Cancelled")
                            {
                                <span class="cancel-reason-text">@(string.IsNullOrWhiteSpace(a.CancelReason) ? "Không ghi" : a.CancelReason)</span>
                            }
                            else
                            {
                                <span class="muted-action">--</span>
                            }
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="10" class="empty-table-text">Bạn chưa có lịch khám nào.</td>
                </tr>
            }
        </tbody>
    </table>
</section>
<script>
    function askCancelReason(form) {
        const reason = prompt('Nhập lý do hủy lịch hẹn nếu có:');
        if (reason === null) return false;
        form.querySelector('input[name="cancelReason"]').value = reason || '';
        return true;
    }
</script>
