@model List<AppointmentDetailDTO>
@{
    ViewData["Title"] = "Lịch khám của tôi";
}

<section class="schedule-list full">
    <h3>Lịch khám của tôi</h3>
    <table>
        <thead>
            <tr>
                <th>Mã lịch hẹn</th>
                <th>Bác sĩ</th>
                <th>Chuyên khoa</th>
                <th>Dịch vụ</th>
                <th>Phòng khám</th>
                <th>Ngày khám</th>
                <th>Giờ khám</th>
                <th>Lý do</th>
                <th>Trạng thái</th>
                <th>Lý do hủy</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Any())
            {
                foreach (var a in Model)
                {
                    <tr>
                        <td>@a.AppointmentId</td>
                        <td>@a.DoctorName</td>
                        <td>@a.SpecialtyName</td>
                        <td>@a.MedicalServiceName</td>
                        <td>@a.ClinicRoomName</td>
                        <td>@a.WorkDate.ToString("dd/MM/yyyy")</td>
                        <td>@a.StartTime.ToString(@"hh\:mm") - @a.EndTime.ToString(@"hh\:mm")</td>
                        <td>@(string.IsNullOrWhiteSpace(a.Reason) ? "Không ghi" : a.Reason)</td>
                        <td><span class="status-pill @a.Status.ToLower()">@a.Status</span></td>
                        <td>@(a.Status == "Cancelled" ? (string.IsNullOrWhiteSpace(a.CancelReason) ? "Không ghi" : a.CancelReason) : "--")</td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="10" class="empty-table-text">Bạn chưa có lịch khám nào.</td>
                </tr>
            }
        </tbody>
    </table>
</section>
