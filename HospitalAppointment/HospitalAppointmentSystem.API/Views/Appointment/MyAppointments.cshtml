@model List<AppointmentDetailDTO>
@{
    ViewData["Title"] = "Lịch khám của tôi";
}

<section class="schedule-list full">
    <h3>Lịch khám của bệnh nhân demo</h3>
    <table>
        <thead>
            <tr>
                <th>Mã lịch hẹn</th>
                <th>Bác sĩ</th>
                <th>Chuyên khoa</th>
                <th>Ngày khám</th>
                <th>Giờ khám</th>
                <th>Lý do</th>
                <th>Trạng thái</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var a in Model)
            {
                <tr>
                    <td>@a.AppointmentId</td>
                    <td>@a.DoctorName</td>
                    <td>@a.SpecialtyName</td>
                    <td>@a.WorkDate.ToString("dd/MM/yyyy")</td>
                    <td>@a.StartTime.ToString(@"hh\:mm") - @a.EndTime.ToString(@"hh\:mm")</td>
                    <td>@a.Reason</td>
                    <td>@a.Status</td>
                </tr>
            }
        </tbody>
    </table>
</section>
