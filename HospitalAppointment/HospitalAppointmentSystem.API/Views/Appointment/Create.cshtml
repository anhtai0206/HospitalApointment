@model AppointmentDTO
@{
    ViewData["Title"] = "Đăng ký lịch khám";
    int? selectedSpecialtyId = ViewBag.SelectedSpecialtyId as int?;
    int? selectedDoctorId = ViewBag.SelectedDoctorId as int?;
    PatientProfileDTO? patientProfile = ViewBag.PatientProfile as PatientProfileDTO;
    var patientPhoto = patientProfile?.PhotoUrl;
}

<div class="page-header">
    <div>
        <p class="eyebrow">Đăng ký trực tuyến</p>
        <h1>Đăng ký lịch khám bệnh</h1>
        
    </div>
    <a href="/Appointment/MyAppointments" class="ghost-link">Xem lịch của tôi</a>
</div>

<form id="filterForm" method="get" asp-action="Create" class="filter-card">
    <div class="filter-group">
        <label>Chuyên khoa</label>
        <select id="specialtyId" name="specialtyId" class="form-control">
            <option value="">-- Tất cả chuyên khoa --</option>
            @foreach (var item in ViewBag.Specialties)
            {
                if (selectedSpecialtyId == item.SpecialtyId)
                {
                    <option value="@item.SpecialtyId" selected>@item.SpecialtyName</option>
                }
                else
                {
                    <option value="@item.SpecialtyId">@item.SpecialtyName</option>
                }
            }
        </select>
    </div>

    <div class="filter-group">
        <label>Bác sĩ</label>
        <select id="doctorFilter" name="doctorId" class="form-control">
            <option value="">-- Tất cả bác sĩ --</option>
            @foreach (var item in ViewBag.Doctors)
            {
                if (selectedDoctorId == item.DoctorId)
                {
                    <option value="@item.DoctorId" selected>@item.FullName</option>
                }
                else
                {
                    <option value="@item.DoctorId">@item.FullName</option>
                }
            }
        </select>
    </div>

    <button type="button" class="btn-refresh" onclick="location.href='/Appointment/Create'">Làm mới</button>
</form>

<div class="booking-layout">
    <section class="panel schedule-panel">
        <div class="panel-title-row">
            <div>
                <h3>Danh sách lịch khám còn trống</h3>
            </div>
            <span class="count-badge">@ViewBag.Schedules.Count lịch</span>
        </div>

        <div class="table-wrap">
            <table class="modern-table">
                <thead>
                    <tr>
                        <th>Chọn</th>
                        <th>Mã lịch</th>
                        <th>Bác sĩ</th>
                        <th>Chuyên khoa</th>
                        <th>Ngày khám</th>
                        <th>Giờ khám</th>
                        <th>Còn trống</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var s in ViewBag.Schedules)
                    {
                        var dateText = s.WorkDate.ToString("dd/MM/yyyy");
                        var timeText = s.StartTime.ToString(@"hh\:mm") + " - " + s.EndTime.ToString(@"hh\:mm");
                        <tr class="schedule-row"
                            data-schedule-id="@s.ScheduleId"
                            data-doctor-id="@s.DoctorId"
                            data-specialty-id="@s.SpecialtyId"
                            data-doctor-name="@s.DoctorName"
                            data-specialty-name="@s.SpecialtyName"
                            data-work-date="@dateText"
                            data-time="@timeText"
                            onclick="selectSchedule(this)">
                            <td>
                                <button type="button" class="select-check" aria-label="Chọn lịch">
                                    <span class="check-icon">✓</span>
                                </button>
                            </td>
                            <td class="strong">@s.ScheduleId</td>
                            <td>@s.DoctorName</td>
                            <td>@s.SpecialtyName</td>
                            <td>@dateText</td>
                            <td>@timeText</td>
                            <td><span class="slot-badge">@s.AvailableSlots slot</span></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>

    <section class="panel patient-form">
        <div class="panel-title-row compact">
            <div>
                <h3>Thông tin đăng ký</h3>
            </div>
        </div>

        <div class="booking-patient-photo-row">
            <div class="booking-avatar">
                @if (!string.IsNullOrWhiteSpace(patientPhoto))
                {
                    <img src="@patientPhoto" alt="Ảnh bệnh nhân" />
                }
                else
                {
                    <span>3x4</span>
                }
            </div>
            <div>
                <strong>@(patientProfile?.FullName ?? "Bệnh nhân")</strong>
                <a href="/Account/PatientInfo">Cập nhật ảnh hồ sơ</a>
            </div>
        </div>

        <div id="selectedBox" class="selected-box empty">
            <div class="selected-icon">✓</div>
            <div>
                <strong>Chưa chọn lịch khám</strong>
            </div>
        </div>

        <form asp-action="Create" method="post" onsubmit="return validateBooking()">
            <input type="hidden" id="ScheduleId" name="ScheduleId" />
            <input type="hidden" id="DoctorId" name="DoctorId" />
            <input type="hidden" asp-for="PatientId" />

            <div class="booking-tabs">
                <div class="tab-block disabled-block" id="serviceBlock">
                    <div class="tab-title">Dịch vụ</div>
                    <select id="MedicalServiceId" name="MedicalServiceId" class="form-control wide-select" disabled>
                        <option value="">-- Chọn dịch vụ --</option>
                        @foreach (var service in ViewBag.Services)
                        {
                            <option value="@service.MedicalServiceId">@service.ServiceName - @service.Description</option>
                        }
                    </select>
                </div>

                <div class="tab-block disabled-block" id="roomBlock">
                    <div class="tab-title">Chọn phòng khám</div>
                    <select id="ClinicRoomId" name="ClinicRoomId" class="form-control wide-select" disabled>
                        <option value="">-- Chọn phòng khám --</option>
                        @foreach (var room in ViewBag.Rooms)
                        {
                            <option value="@room.ClinicRoomId" data-specialty-id="@room.SpecialtyId">@room.RoomName</option>
                        }
                    </select>
                </div>
            </div>

            <div class="form-row stacked">
                <label>Lý do khám</label>
                <textarea name="Reason" placeholder="Nhập triệu chứng hoặc lý do khám..."></textarea>
            </div>

            <div class="button-group single">
                <button type="submit" class="btn-save">Đăng ký</button>
            </div>
        </form>
    </section>
</div>

<script>
    const roomSelect = document.getElementById('ClinicRoomId');
    const serviceSelect = document.getElementById('MedicalServiceId');
    const allRoomOptions = Array.from(roomSelect.querySelectorAll('option'));

    document.getElementById('specialtyId').addEventListener('change', function () {
        document.getElementById('doctorFilter').value = '';
        document.getElementById('filterForm').submit();
    });

    document.getElementById('doctorFilter').addEventListener('change', function () {
        document.getElementById('filterForm').submit();
    });

    function selectSchedule(row) {
        document.querySelectorAll('.schedule-row').forEach(function (item) {
            item.classList.remove('selected');
        });

        row.classList.add('selected');

        const scheduleId = row.dataset.scheduleId;
        const doctorId = row.dataset.doctorId;
        const specialtyId = row.dataset.specialtyId;
        const doctorName = row.dataset.doctorName;
        const specialtyName = row.dataset.specialtyName;
        const workDate = row.dataset.workDate;
        const time = row.dataset.time;

        document.getElementById('ScheduleId').value = scheduleId;
        document.getElementById('DoctorId').value = doctorId;

        enableBookingOptions(specialtyId);

        const selectedBox = document.getElementById('selectedBox');
        selectedBox.classList.remove('empty');
        selectedBox.innerHTML = `
            <div class="selected-icon">✓</div>
            <div>
                <strong>Đã chọn lịch #${scheduleId}</strong>
                <span>${doctorName} - ${specialtyName}</span>
                <span>${workDate}, ${time}</span>
            </div>`;
    }

    function enableBookingOptions(specialtyId) {
        document.getElementById('serviceBlock').classList.remove('disabled-block');
        document.getElementById('roomBlock').classList.remove('disabled-block');
        serviceSelect.disabled = false;
        roomSelect.disabled = false;
        serviceSelect.value = '';

        roomSelect.innerHTML = '';
        const defaultOption = allRoomOptions[0].cloneNode(true);
        roomSelect.appendChild(defaultOption);

        allRoomOptions.slice(1).forEach(function (option) {
            if (option.dataset.specialtyId === specialtyId) {
                roomSelect.appendChild(option.cloneNode(true));
            }
        });
        roomSelect.value = '';
    }

    function validateBooking() {
        if (!document.getElementById('ScheduleId').value) {
            showBookingMessage('Vui lòng chọn bác sĩ và lịch khám trước.');
            return false;
        }
        if (!serviceSelect.value) {
            showBookingMessage('Vui lòng chọn dịch vụ khám.');
            return false;
        }
        if (!roomSelect.value) {
            showBookingMessage('Vui lòng chọn phòng khám phù hợp với chuyên khoa.');
            return false;
        }
        return true;
    }

    function showBookingMessage(message) {
        const selectedBox = document.getElementById('selectedBox');
        selectedBox.classList.add('empty', 'shake');
        selectedBox.innerHTML = `
            <div class="selected-icon">!</div>
            <div>
                <strong>${message}</strong>
            </div>`;
        setTimeout(function () { selectedBox.classList.remove('shake'); }, 400);
    }
</script>
