        const medbookOriginalText = new WeakMap();
        const medbookOriginalAttrs = new WeakMap();

        function translateTextValue(value, lang) {
            if (!value) return value;
            const match = value.match(/^(\s*)(.*?)(\s*)$/s);
            const key = match ? match[2] : value;
            const translated = lang === 'vi' ? key : (medbookTranslations.en[key] || key);
            return (match ? match[1] : '') + translated + (match ? match[3] : '');
        }

        function translateDom(lang) {
            document.documentElement.lang = lang === 'en' ? 'en' : 'vi';
            const flag = document.getElementById('languageFlag');
            const name = document.getElementById('languageName');
            if (flag) flag.textContent = lang === 'en' ? 'EN' : 'VN';
            if (name) name.textContent = lang === 'en' ? 'English' : 'Tiếng Việt';
            document.getElementById('languageMenu')?.classList.remove('open');

            const walker = document.createTreeWalker(document.body, NodeFilter.SHOW_TEXT, {
                acceptNode(node) {
                    const parent = node.parentElement;
                    if (!parent) return NodeFilter.FILTER_REJECT;
                    if (['SCRIPT', 'STYLE', 'TEXTAREA'].includes(parent.tagName)) return NodeFilter.FILTER_REJECT;
                    if (!node.nodeValue || !node.nodeValue.trim()) return NodeFilter.FILTER_REJECT;
                    return NodeFilter.FILTER_ACCEPT;
                }
            });
            const nodes = [];
            while (walker.nextNode()) nodes.push(walker.currentNode);
            nodes.forEach(node => {
                if (!medbookOriginalText.has(node)) medbookOriginalText.set(node, node.nodeValue);
                node.nodeValue = translateTextValue(medbookOriginalText.get(node), lang);
            });

            document.querySelectorAll('[placeholder], [title], [aria-label]').forEach(el => {
                ['placeholder', 'title', 'aria-label'].forEach(attr => {
                    if (!el.hasAttribute(attr)) return;
                    let map = medbookOriginalAttrs.get(el);
                    if (!map) { map = {}; medbookOriginalAttrs.set(el, map); }
                    if (!map[attr]) map[attr] = el.getAttribute(attr);
                    const base = map[attr];
                    const translated = lang === 'vi' ? base : (medbookPlaceholders.en[base] || medbookTranslations.en[base] || base);
                    el.setAttribute(attr, translated);
                });
            });
        }

        function setLanguage(lang) {
            localStorage.setItem('medbookLang', lang);
            translateDom(lang);
        }

        function toggleLanguageMenu() {
            document.getElementById('languageMenu')?.classList.toggle('open');
        }

        document.addEventListener('click', function (event) {
            const box = document.querySelector('.language-switcher');
            if (box && !box.contains(event.target)) document.getElementById('languageMenu')?.classList.remove('open');
        });


        function showAppModal(message, type) {
            if (!message) return;
            const overlay = document.getElementById('appModal');
            const icon = document.getElementById('appModalIcon');
            const title = document.getElementById('appModalTitle');
            const text = document.getElementById('appModalMessage');
            overlay.style.display = 'flex';
            text.textContent = message;
            if (type === 'error') {
                icon.textContent = '!';
                icon.className = 'app-modal-icon error';
                title.textContent = 'Không thành công';
            } else {
                icon.textContent = '✓';
                icon.className = 'app-modal-icon success';
                title.textContent = 'Thành công';
            }
        }


        function togglePassword(button) {
            const wrapper = button.closest('.auth-basic-input, .password-field');
            const input = wrapper ? wrapper.querySelector('input') : null;
            if (!input) return;
            const show = input.type === 'password';
            input.type = show ? 'text' : 'password';
            button.textContent = show ? '🙈' : '👁';
            button.setAttribute('aria-label', show ? 'Ẩn mật khẩu' : 'Hiện mật khẩu');
        }

        function requireLoginFromFooter(loginUrl) {
            showAppModal('Bạn cần đăng nhập để sử dụng chức năng này.', 'error');
            setTimeout(function () { window.location.href = loginUrl || '/Account/Login'; }, 900);
            return false;
        }

        function closeAppModal() {
            document.getElementById('appModal').style.display = 'none';
        }

        document.addEventListener('DOMContentLoaded', function () {
            const savedLang = localStorage.getItem('medbookLang') || 'vi';
            translateDom(savedLang);
            if (window.appTempSuccess) showAppModal(window.appTempSuccess, 'success');
            if (window.appTempError) showAppModal(window.appTempError, 'error');
        });
    </script>
</body>
</html>
