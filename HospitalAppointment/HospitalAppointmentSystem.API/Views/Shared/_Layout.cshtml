@using System.Security.Claims
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Đăng ký lịch khám</title>
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    <div class="clinic-page">
        <aside class="sidebar">
            <div class="logo-box">
                <div class="logo-icon">🏥</div>
                <div>
                    <strong>MEDBOOK</strong>
                    <span>Đặt lịch khám</span>
                </div>
            </div>
            <a href="/">Trang chủ</a>

            @if (User.Identity?.IsAuthenticated == true && User.IsInRole("Patient"))
            {
                <a href="/Appointment/MyAppointments">Lịch của tôi</a>
                <a href="/Account/PatientInfo">Thông tin bệnh nhân</a>
            }

            @if (User.Identity?.IsAuthenticated == true && User.IsInRole("Doctor"))
            {
                <a href="/Doctor/MySchedule">Lịch khám của bác sĩ</a>
            }

            @if (User.Identity?.IsAuthenticated == true && User.IsInRole("Admin"))
            {
                <a href="/Admin/Appointments">Quản lý lịch hẹn</a>
                <a href="/swagger">Web API</a>
            }

            @if (User.Identity?.IsAuthenticated == true)
            {
                <a href="/Account/ChangePassword">Đổi mật khẩu</a>
                <div class="user-card">
                    <strong>@User.Identity!.Name</strong>
                    <span>@(User.IsInRole("Admin") ? "Quản trị viên" : User.IsInRole("Doctor") ? "Bác sĩ" : "Bệnh nhân")</span>
                </div>
                <form asp-controller="Account" asp-action="Logout" method="post">
                    <button class="sidebar-action logout-button" type="submit">Đăng xuất</button>
                </form>
            }
            else
            {
                <a href="/Account/Login">Đăng nhập</a>
            }
        </aside>
        <main class="content">
            <div class="language-switcher" aria-label="Chọn ngôn ngữ">
                <button type="button" id="languageToggle" class="language-toggle" onclick="toggleLanguageMenu()">
                    <span id="languageFlag">VN</span>
                    <span id="languageName">Tiếng Việt</span>
                    <span class="language-caret">▾</span>
                </button>
                <div id="languageMenu" class="language-menu">
                    <button type="button" onclick="setLanguage('vi')"><span>VN</span> Tiếng Việt</button>
                    <button type="button" onclick="setLanguage('en')"><span>EN</span> English</button>
                </div>
            </div>
            @RenderBody()

            <footer class="site-footer" id="siteFooter">
                <div class="footer-brand">
                    <div class="footer-logo-row">
                        <div class="footer-logo-mark">✚</div>
                        <div>
                            <span class="footer-hospital-small">BỆNH VIỆN ĐA KHOA QUỐC TẾ</span>
                            <strong>MEDBOOK</strong>
                        </div>
                    </div>
                    <p><strong>Địa chỉ:</strong> Số 88, Đường số 8, Khu dân cư Trung Sơn, TP. Hồ Chí Minh</p>
                    <p><strong>Email:</strong> dichvukhachhang@medbook.vn</p>
                    <p><strong>Giấy phép hoạt động:</strong> 230/BYT-GPHĐ do Bộ Y tế cấp.</p>
                </div>

                <div class="footer-column">
                    <h4>Về chúng tôi</h4>
                    <a href="#doctorSection">Đội ngũ bác sĩ</a>
                    <a href="#bookingSection">Đặt lịch khám</a>
                    <a href="/Account/PatientInfo">Hồ sơ bệnh nhân</a>
                    <a href="/Appointment/MyAppointments">Lịch khám của tôi</a>
                    <a href="/Account/ChangePassword">Đổi mật khẩu</a>
                </div>

                <div class="footer-column">
                    <h4>Giờ làm việc</h4>
                    <p>Từ thứ 2 đến thứ 7</p>
                    <p>Buổi sáng:<br /><strong>07:30 – 12:00</strong></p>
                    <p>Buổi chiều:<br /><strong>13:30 – 18:00</strong></p>
                    <a class="footer-hotline" href="tel:18006767">Hotline: 1800 6767</a>
                </div>

                <div class="footer-column">
                    <h4>Liên hệ</h4>
                    <div class="footer-socials">
                        <a href="https://facebook.com" target="_blank" rel="noopener" aria-label="Facebook">f</a>
                        <a href="https://youtube.com" target="_blank" rel="noopener" aria-label="YouTube">▶</a>
                        <a href="https://zalo.me/18006767" target="_blank" rel="noopener" aria-label="Zalo">Zalo</a>
                    </div>
                    <p class="newsletter-title">Theo dõi bản tin chúng tôi</p>
                    <form class="newsletter-form" onsubmit="event.preventDefault(); showAppModal('Cảm ơn bạn đã đăng ký nhận bản tin.', 'success');">
                        <input type="email" placeholder="Nhập email của bạn" aria-label="Email nhận bản tin" />
                        <button type="submit">Đăng ký</button>
                    </form>
                    <div class="dmca-box">✓ DMCA PROTECTED</div>
                </div>
            </footer>
        </main>
    </div>

    <div class="floating-contact" aria-label="Liên hệ nhanh">
        <a class="float-btn hotline" href="tel:18006767" title="Gọi hotline">☎<span>Hotline</span></a>
        <a class="float-btn fanpage" href="https://facebook.com" target="_blank" rel="noopener" title="Fanpage">💬<span>Fanpage</span></a>
        <a class="float-btn zalo" href="https://zalo.me/18006767" target="_blank" rel="noopener" title="Zalo">Zalo<span>Zalo</span></a>
    </div>

    <div id="appModal" class="app-modal-overlay" style="display:none;">
        <div class="app-modal-card">
            <div id="appModalIcon" class="app-modal-icon">✓</div>
            <h3 id="appModalTitle">Thông báo</h3>
            <p id="appModalMessage"></p>
            <button type="button" onclick="closeAppModal()" class="app-modal-button">Đóng</button>
        </div>
    </div>

    <script>
        window.appTempSuccess = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(TempData["Success"]));
        window.appTempError = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(TempData["Error"]));

        function showAppModal(message, type) {
            if (!message) return;
            const overlay = document.getElementById('appModal');
            const icon = document.getElementById('appModalIcon');
            const title = document.getElementById('appModalTitle');
            const text = document.getElementById('appModalMessage');
            overlay.style.display = 'flex';
            text.textContent = message;
            if (type === 'error') {
                icon.textContent = '!';
                icon.className = 'app-modal-icon error';
                title.textContent = 'Không thành công';
            } else {
                icon.textContent = '✓';
                icon.className = 'app-modal-icon success';
                title.textContent = 'Thành công';
            }
        }


        function togglePassword(button) {
            const wrapper = button.closest('.auth-basic-input, .password-field');
            const input = wrapper ? wrapper.querySelector('input') : null;
            if (!input) return;
            const show = input.type === 'password';
            input.type = show ? 'text' : 'password';
            button.textContent = show ? '🙈' : '👁';
            button.setAttribute('aria-label', show ? 'Ẩn mật khẩu' : 'Hiện mật khẩu');
        }

