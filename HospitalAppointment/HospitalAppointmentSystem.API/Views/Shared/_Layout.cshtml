                'Nhập lại mật khẩu mới': 'Confirm new password',
                'Nhập lại mật khẩu': 'Confirm password',
                'Nhập email của bạn': 'Enter your email',
                '-- Chọn chuyên khoa --': '-- Select specialty --',
                '-- Chọn bác sĩ --': '-- Select doctor --',
                '-- Chọn giờ khám --': '-- Select time slot --',
                '-- Chọn dịch vụ --': '-- Select service --',
                '-- Chọn phòng khám --': '-- Select clinic room --'
            }
        };

        function translateText(text) {
            const lang = localStorage.getItem('medbookLang') || 'vi';
            return lang === 'vi' ? text : (medbookTranslations.en[text] || text);
        }
        window.medbookT = translateText;

        const translatedTextNodes = new WeakMap();
        function applyLanguage(lang) {
            localStorage.setItem('medbookLang', lang);
            document.documentElement.lang = lang;
            document.getElementById('languageFlag').textContent = lang === 'vi' ? 'VN' : 'EN';
            document.getElementById('languageName').textContent = lang === 'vi' ? 'Tiếng Việt' : 'English';
            document.getElementById('languageMenu')?.classList.remove('open');

            const walker = document.createTreeWalker(document.body, NodeFilter.SHOW_TEXT, {
                acceptNode(node) {
                    const parent = node.parentElement;
                    if (!parent) return NodeFilter.FILTER_REJECT;
                    if (['SCRIPT', 'STYLE', 'TEXTAREA'].includes(parent.tagName)) return NodeFilter.FILTER_REJECT;
                    if (!node.nodeValue || !node.nodeValue.trim()) return NodeFilter.FILTER_REJECT;
                    return NodeFilter.FILTER_ACCEPT;
                }
            });
            const nodes = [];
            while (walker.nextNode()) nodes.push(walker.currentNode);
            nodes.forEach(node => {
                if (!translatedTextNodes.has(node)) translatedTextNodes.set(node, node.nodeValue);
                const base = translatedTextNodes.get(node);
                const leading = base.match(/^\s*/)[0];
                const trailing = base.match(/\s*$/)[0];
                const key = base.trim();
                let translatedKey = medbookTranslations.en[key] || key;
                if (lang !== 'vi') {
                    const expMatch = key.match(/^(\d+)\s+năm kinh nghiệm$/i);
                    if (expMatch) translatedKey = `${expMatch[1]} years of experience`;
                    const doctorNameMatch = key.match(/^BS\.\s+(.+)$/i);
                    if (doctorNameMatch) translatedKey = `Dr. ${doctorNameMatch[1]}`;
                }
                node.nodeValue = lang === 'vi' ? base : leading + translatedKey + trailing;
            });

            document.querySelectorAll('input[placeholder], textarea[placeholder], select option').forEach(el => {
                if (!el.dataset.baseText) el.dataset.baseText = el.placeholder || el.textContent || '';
                const base = el.dataset.baseText;
                const translated = lang === 'vi' ? base : (medbookPlaceholders.en[base] || medbookTranslations.en[base] || base);
                if ('placeholder' in el && el.placeholder) el.placeholder = translated;
                else el.textContent = translated;
            });
            document.querySelectorAll('[title], [aria-label]').forEach(el => {
                if (el.title) {
                    if (!el.dataset.baseTitle) el.dataset.baseTitle = el.title;
                    el.title = lang === 'vi' ? el.dataset.baseTitle : (medbookTranslations.en[el.dataset.baseTitle] || el.dataset.baseTitle);
                }
                const aria = el.getAttribute('aria-label');
                if (aria) {
                    if (!el.dataset.baseAria) el.dataset.baseAria = aria;
                    el.setAttribute('aria-label', lang === 'vi' ? el.dataset.baseAria : (medbookTranslations.en[el.dataset.baseAria] || el.dataset.baseAria));
                }
            });
        }

        function setLanguage(lang) { applyLanguage(lang); }
        function toggleLanguageMenu() { document.getElementById('languageMenu')?.classList.toggle('open'); }
        document.addEventListener('click', function(e) {
            const box = document.querySelector('.language-switcher');
            if (box && !box.contains(e.target)) document.getElementById('languageMenu')?.classList.remove('open');
        });

        document.addEventListener('DOMContentLoaded', function () {
            if (window.appTempSuccess) showAppModal(window.appTempSuccess, 'success');
            if (window.appTempError) showAppModal(window.appTempError, 'error');
            applyLanguage(localStorage.getItem('medbookLang') || 'vi');
        });
    </script>
</body>
</html>
