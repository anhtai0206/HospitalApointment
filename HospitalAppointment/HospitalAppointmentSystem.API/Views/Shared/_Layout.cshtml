<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Đăng ký lịch khám</title>
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    <div class="clinic-page">
        <aside class="sidebar">
            <div class="logo-box">
                <div class="logo-icon">🏥</div>
                <div>
                    <strong>MEDBOOK</strong>
                    <span>Đặt lịch khám</span>
                </div>
            </div>
            <a href="/">Trang chủ</a>
            <a href="/Doctor">Bác sĩ</a>
            <a href="/Appointment/Create">Đăng ký khám</a>
            <a href="/Appointment/MyAppointments">Lịch của tôi</a>
            <a href="/Admin/Appointments">Quản lý lịch hẹn</a>
            <a href="/swagger">Web API</a>
        </aside>
        <main class="content">
            @if (TempData["Success"] != null)
            {
                <div class="alert success">@TempData["Success"]</div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert error">@TempData["Error"]</div>
            }
            @RenderBody()
        </main>
    </div>
</body>
</html>
