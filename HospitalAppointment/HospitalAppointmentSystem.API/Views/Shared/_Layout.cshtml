        const medbookPlaceholders = {
            en: {
                'Nhập tên bác sĩ...': 'Enter doctor name...',
                'Có thể để trống hoặc nhập triệu chứng...': 'Optional: enter symptoms...',
                'Nhập email': 'Enter email',
                'Nhập mật khẩu': 'Enter password',
