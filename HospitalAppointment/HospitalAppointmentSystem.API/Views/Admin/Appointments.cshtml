@model List<AppointmentDetailDTO>
@{
    ViewData["Title"] = "Quản lý lịch hẹn";
}

<section class="schedule-list full">
    <h3>Quản lý lịch hẹn khám bệnh</h3>
    <table>
        <thead>
            <tr>
                <th>Mã</th>
                <th>Bệnh nhân</th>
                <th>Bác sĩ</th>
                <th>Chuyên khoa</th>
                <th>Dịch vụ</th>
                <th>Phòng khám</th>
                <th>Ngày</th>
                <th>Giờ</th>
                <th>Lý do</th>
                <th>Trạng thái</th>
                <th>Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var a in Model)
            {
                <tr>
                    <td>@a.AppointmentId</td>
                    <td>@a.PatientName</td>
                    <td>@a.DoctorName</td>
                    <td>@a.SpecialtyName</td>
                    <td>@a.MedicalServiceName</td>
                    <td>@a.ClinicRoomName</td>
                    <td>@a.WorkDate.ToString("dd/MM/yyyy")</td>
                    <td>@a.StartTime.ToString(@"hh\:mm") - @a.EndTime.ToString(@"hh\:mm")</td>
                    <td>@(string.IsNullOrWhiteSpace(a.Reason) ? "Không ghi" : a.Reason)</td>
                    <td><span class="status-pill @a.Status.ToLower()">@a.Status</span></td>
                    <td class="actions">
                        @if (a.Status == "Pending")
                        {
                            <form asp-action="Confirm" method="post"><input type="hidden" name="id" value="@a.AppointmentId" /><button class="action-confirm">Xác nhận</button></form>
                            <form asp-action="Complete" method="post"><input type="hidden" name="id" value="@a.AppointmentId" /><button>Đã khám</button></form>
                            <form asp-action="Cancel" method="post" onsubmit="return askCancelReason(this)">
                                <input type="hidden" name="id" value="@a.AppointmentId" />
                                <input type="hidden" name="cancelReason" />
                                <button class="danger-button">Hủy</button>
                            </form>
                        }
                        else if (a.Status == "Cancelled")
                        {
                            <span class="cancel-reason-text">@(string.IsNullOrWhiteSpace(a.CancelReason) ? "Đã hủy" : a.CancelReason)</span>
                        }
                        else
                        {
                            <span class="muted-action">--</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</section>
<script>
    function askCancelReason(form) {
        const reason = prompt('Nhập lý do hủy lịch hẹn nếu có:');
        if (reason === null) return false;
        form.querySelector('input[name="cancelReason"]').value = reason || '';
        return true;
    }
</script>
