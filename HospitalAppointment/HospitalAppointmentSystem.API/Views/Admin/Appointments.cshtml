@model List<AppointmentDetailDTO>
@{
    string StatusLabel(string status) => status switch { "Pending" => "Chờ xác nhận", "Confirmed" => "Đã xác nhận", "Cancelled" => "Đã hủy", "Completed" => "Đã khám", _ => status };
    ViewData["Title"] = "Quản lý lịch hẹn";
}

<section class="schedule-list full">
    <h3>Quản lý lịch hẹn khám bệnh</h3>
    <p class="muted">Trang này chỉ dành cho Admin. Bệnh nhân và bác sĩ sẽ không thấy mục này trên menu.</p>
    <table>
        <thead>
            <tr>
                <th>Mã</th>
                <th>Bệnh nhân</th>
                <th>Bác sĩ</th>
                <th>Chuyên khoa</th>
                <th>Dịch vụ</th>
                <th>Phòng khám</th>
                <th>Ngày</th>
                <th>Giờ</th>
                <th>Lý do</th>
                <th>Trạng thái</th>
                <th>Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var a in Model)
            {
                <tr>
                    <td>@a.AppointmentId</td>
                    <td>@a.PatientName</td>
                    <td>@a.DoctorName</td>
                    <td>@a.SpecialtyName</td>
                    <td>@a.MedicalServiceName</td>
                    <td>@a.ClinicRoomName</td>
                    <td>@a.WorkDate.ToString("dd/MM/yyyy")</td>
                    <td>@a.StartTime.ToString(@"hh\:mm") - @a.EndTime.ToString(@"hh\:mm")</td>
                    <td>@(string.IsNullOrWhiteSpace(a.Reason) ? "Không ghi" : a.Reason)</td>
                    <td><span class="status-pill @a.Status.ToLower()">@StatusLabel(a.Status)</span></td>
                    <td class="actions">
                        @if (a.Status == "Pending")
                        {
                            <form asp-action="Confirm" method="post"><input type="hidden" name="id" value="@a.AppointmentId" /><button class="action-confirm">Xác nhận</button></form>
                        }
                        @if (a.Status != "Cancelled" && a.Status != "Completed")
                        {
                            <form asp-action="Complete" method="post"><input type="hidden" name="id" value="@a.AppointmentId" /><button>Đã khám</button></form>
                            <form asp-action="Cancel" method="post" onsubmit="return confirm('Bạn chắc chắn muốn hủy lịch hẹn này?')"><input type="hidden" name="id" value="@a.AppointmentId" /><button class="danger-button">Hủy</button></form>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</section>
