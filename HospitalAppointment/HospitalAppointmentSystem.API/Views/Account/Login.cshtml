@model LoginDTO
@{
    ViewData["Title"] = "Đăng nhập";
}

<section class="auth-basic-wrap">
    <div class="auth-basic-card">
        <h1>Đăng nhập</h1>

        <form asp-action="Login" method="post" class="auth-basic-form">
            <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />

            <label>Email</label>
            <div class="auth-basic-input">
                <span>👤</span>
                <input asp-for="Email" placeholder="Nhập email" />
            </div>

            <label>Mật khẩu</label>
            <div class="auth-basic-input">
                <span>🔒</span>
                <input asp-for="Password" type="password" placeholder="Nhập mật khẩu" />
            </div>

            <label class="auth-remember">
                <input asp-for="RememberMe" />
                <span>Ghi nhớ đăng nhập</span>
            </label>

            <button class="auth-green-button" type="submit">Đăng nhập</button>

            <div class="auth-basic-links">
                <a href="/Account/Register">Đăng ký tài khoản</a>
                <a href="/Account/ForgotPassword">Quên mật khẩu?</a>
            </div>
        </form>
    </div>
</section>
