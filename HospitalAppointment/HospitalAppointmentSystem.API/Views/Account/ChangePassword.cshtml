@model ChangePasswordDTO
@{
    ViewData["Title"] = "Đổi mật khẩu";
}

<section class="auth-card polished">
    <h2>Đổi mật khẩu</h2>
    <p class="muted">Cập nhật mật khẩu định kỳ để tăng tính bảo mật tài khoản.</p>
    <form asp-action="ChangePassword" method="post" class="auth-form">
        <div class="form-row stacked"><label>Mật khẩu cũ</label><input asp-for="OldPassword" type="password" /></div>
        <div class="form-row stacked"><label>Mật khẩu mới</label><input asp-for="NewPassword" type="password" /></div>
        <div class="form-row stacked"><label>Xác nhận mật khẩu mới</label><input asp-for="ConfirmPassword" type="password" /></div>
        <button class="primary-button" type="submit">Cập nhật mật khẩu</button>
    </form>
</section>
