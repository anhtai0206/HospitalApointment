@model ChangePasswordDTO
@{
    ViewData["Title"] = "Đổi mật khẩu";
}

<section class="auth-card polished">
    <h2>Đổi mật khẩu</h2>
    <p class="muted">Cập nhật mật khẩu định kỳ để tăng tính bảo mật tài khoản.</p>
    <form asp-action="ChangePassword" method="post" class="auth-form">
        <div class="form-row stacked"><label>Mật khẩu cũ</label><div class="password-field"><input asp-for="OldPassword" type="password" /><button type="button" class="password-eye" onclick="togglePassword(this)">👁</button></div></div>
        <div class="form-row stacked"><label>Mật khẩu mới</label><div class="password-field"><input asp-for="NewPassword" type="password" /><button type="button" class="password-eye" onclick="togglePassword(this)">👁</button></div></div>
        <div class="form-row stacked"><label>Xác nhận mật khẩu mới</label><div class="password-field"><input asp-for="ConfirmPassword" type="password" /><button type="button" class="password-eye" onclick="togglePassword(this)">👁</button></div></div>
        <button class="primary-button" type="submit">Cập nhật mật khẩu</button>
    </form>
</section>
