@model ForgotPasswordDTO
@{
    ViewData["Title"] = "Quên mật khẩu";
}

<section class="auth-basic-wrap">
    <div class="auth-basic-card">
        <h1>Quên mật khẩu</h1>

        <form asp-action="ForgotPassword" method="post" class="auth-basic-form">
            <label>Email</label>
            <div class="auth-basic-input">
                <span>✉️</span>
                <input asp-for="Email" placeholder="Nhập email" />
            </div>

            <label>Mật khẩu mới</label>
            <div class="auth-basic-input">
                <span>🔒</span>
                <input asp-for="NewPassword" type="password" placeholder="Nhập mật khẩu mới" />
                <button type="button" class="password-eye" onclick="togglePassword(this)" aria-label="Hiện mật khẩu">👁</button>
            </div>

            <label>Nhập lại mật khẩu mới</label>
            <div class="auth-basic-input">
                <span>🔒</span>
                <input asp-for="ConfirmPassword" type="password" placeholder="Nhập lại mật khẩu mới" />
                <button type="button" class="password-eye" onclick="togglePassword(this)" aria-label="Hiện mật khẩu">👁</button>
            </div>

            <button class="auth-green-button" type="submit">Cập nhật mật khẩu</button>

            <div class="auth-basic-links single">
                <a href="/Account/Login">Quay lại đăng nhập</a>
            </div>
        </form>
    </div>
</section>
