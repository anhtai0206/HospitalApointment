@model RegisterPatientDTO
@{
    ViewData["Title"] = "Đăng ký";
}

<section class="auth-basic-wrap">
    <div class="auth-basic-card">
        <h1>Đăng ký</h1>

        <form asp-action="Register" method="post" class="auth-basic-form">
            <label>Email</label>
            <div class="auth-basic-input">
                <span>✉️</span>
                <input asp-for="Email" placeholder="Nhập email" />
            </div>

            <label>Mật khẩu</label>
            <div class="auth-basic-input">
                <span>🔒</span>
                <input asp-for="Password" type="password" placeholder="Nhập mật khẩu" />
                <button type="button" class="password-eye" onclick="togglePassword(this)" aria-label="Hiện mật khẩu">👁</button>
            </div>

            <label>Nhập lại mật khẩu</label>
            <div class="auth-basic-input">
                <span>🔒</span>
                <input asp-for="ConfirmPassword" type="password" placeholder="Nhập lại mật khẩu" />
                <button type="button" class="password-eye" onclick="togglePassword(this)" aria-label="Hiện mật khẩu">👁</button>
            </div>

            <button class="auth-green-button" type="submit">Tạo tài khoản</button>

            <div class="auth-basic-links single">
                <a href="/Account/Login">Đã có tài khoản? Đăng nhập</a>
            </div>
        </form>
    </div>
</section>
